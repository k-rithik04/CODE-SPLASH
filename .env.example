# Google Apps Script webhook URL for school registration submissions
WEBHOOK_URL=https://script.google.com/macros/s/<YOUR_SCRIPT_ID>/exec
# Public version (available in browser) — needed for GitHub Pages static export
NEXT_PUBLIC_WEBHOOK_URL=https://script.google.com/macros/s/<YOUR_SCRIPT_ID>/exec

# Next.js
NEXT_PUBLIC_BASE_PATH="" # Set to /CODE-SPLASH for GitHub Pages static export
NEXT_STATIC_EXPORT=false  # Set to true for GitHub Pages static export

# Supabase (CMS + Auth)
NEXT_PUBLIC_SUPABASE_URL=https://gcymcwaocowoczvvsaxw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImdjeW1jd2FvY293b2N6dnZzYXh3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMwMDA3OTAsImV4cCI6MjA5ODU3Njc5MH0.pLyrBDsoBb-Bzidho7_SkpECR39KC6V6U3db7759by8
